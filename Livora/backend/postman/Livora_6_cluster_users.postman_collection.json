    {
      "name": "You — login main account",
      "item": [
        {
          "name": "Login (set token_main)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (pm.response.code === 200 && j.access_token) {",
                  "    pm.collectionVariables.set('token_main', j.access_token);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"YOUR_EMAIL@example.com\",\n  \"password\": \"YOUR_PASSWORD\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Edit email/password. On success, token_main is set for Match AI."
          }
        },
        {
          "name": "Apply your questionnaire (optional)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_main}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"age\": 23,\n  \"income\": 50000,\n  \"expenses\": 32000,\n  \"social_habit_score\": 0.5,\n  \"drinks\": \"socially\",\n  \"smokes\": \"no\",\n  \"drugs\": \"never\",\n  \"pets\": \"likes cats\",\n  \"diet\": \"anything\",\n  \"education\": \"graduated from college/university\",\n  \"body_type\": \"average\",\n  \"sex\": \"m\",\n  \"orientation\": \"straight\",\n  \"status\": \"single\",\n  \"region\": \"new york\"\n}"
            },
            "url": "{{baseUrl}}/ml/apply-questionnaire"
          }
        },
        {
          "name": "Match AI — compare with all six users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_main}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/match/ai",
