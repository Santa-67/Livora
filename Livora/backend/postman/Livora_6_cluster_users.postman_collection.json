{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Livora — 6 users + questionnaires (ML clusters)",
    "description": "1) Run each folder in order: Register → Apply questionnaire → My cluster.\n2) Register tests save Bearer tokens to collection variables token_cluster1 … token_cluster6.\n3) Actual cluster IDs depend on roommate_compatibility_model.joblib; use My cluster to see them.\n4) Log in as your main account, complete your questionnaire, then POST /match/ai to compare compatibility with all six.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:5000" },
    { "key": "token_cluster1", "value": "" },
    { "key": "token_cluster2", "value": "" },
    { "key": "token_cluster3", "value": "" },
    { "key": "token_cluster4", "value": "" },
    { "key": "token_cluster5", "value": "" },
    { "key": "token_cluster6", "value": "" },
    { "key": "token_main", "value": "" }
  ],
  "item": [
    {
      "name": "Cluster user 1 — quiet / budget / vegetarian",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if ((pm.response.code === 200 || pm.response.code === 201) && j.access_token) {",
                  "    pm.collectionVariables.set('token_cluster1', j.access_token);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cluster.user1@livora.test\",\n  \"password\": \"ClusterTest1!\",\n  \"name\": \"Arjun Mehta\",\n  \"gender\": \"male\",\n  \"bio\": \"Early nights, quiet flat, veg meals.\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Change email if already registered; then use Login instead."
          }
        },
        {
          "name": "Apply questionnaire",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_cluster1}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"age\": 22,\n  \"income\": 15000,\n  \"expenses\": 12000,\n  \"social_habit_score\": 0.12,\n  \"drinks\": \"not at all\",\n  \"smokes\": \"no\",\n  \"drugs\": \"never\",\n  \"pets\": \"no\",\n  \"diet\": \"vegetarian\",\n  \"education\": \"working on college/university\",\n  \"body_type\": \"thin\",\n  \"sex\": \"m\",\n  \"orientation\": \"straight\",\n  \"status\": \"single\",\n  \"region\": \"other\"\n}"
            },
            "url": "{{baseUrl}}/ml/apply-questionnaire"
          }
        },
        {
          "name": "My cluster",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_cluster1}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/ml/my-cluster"
          }
        }
      ]
    },
